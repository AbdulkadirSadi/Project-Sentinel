# ── Database (docker-compose tarafından override edilir) ─────────────────────
DATABASE_URL=postgresql://sentinel:change_me_strong_db_password@localhost:5432/sentinel_db

# ── VirusTotal (isteğe bağlı — virustotal.com'dan ücretsiz key) ─────────────
VT_API_KEY=

# ── Auth Secrets (generate with: openssl rand -hex 32) ──────────────────────
JWT_SECRET=change_me_jwt_secret
INTERNAL_SECRET=change_me_internal_secret
ADMIN_PASSWORD=change_me_admin_password

# ── Detection Thresholds ─────────────────────────────────────────────────────
ACTION_THRESHOLD=90
ALERT_THRESHOLD=70
VT_MIN_POSITIVES=5

# ── Server API (docker-compose tarafından override edilir) ───────────────────
SERVER_API=http://sentinel-server:8081
